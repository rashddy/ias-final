# Server port
PORT=3001

# Comma-separated allowed frontend origins
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Firebase Web API key (Project Settings → General → Web API Key)
FIREBASE_API_KEY=your_firebase_web_api_key

# Path to Firebase service account JSON
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# SMTP (Nodemailer) — required for login OTP emails
# Gmail example: use an App Password (Google Account → Security → App passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="ISOGuard" <your-email@gmail.com>
